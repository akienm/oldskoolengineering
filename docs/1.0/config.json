        "\\*?([\\w\\s.,&'()\\-]+? v\\. [\\w\\s.,&'()\\-]+?)\\*?, (\\d{4}) ([A-Z][a-z]+\\.) App\\. ?,? ([A-Za-z]+\\. \\d{1,2}, \\d{4})",
        "\\*?([\\w\\s.,&'()\\-]+? v\\. [\\w\\s.,&'()\\-]+?)\\*?, (\\d+) ([A-Z][a-z]+\\.3d) (\\d+)"
